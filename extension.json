{
	"name": "WikiPoints",
	"author": "Tali64",
	"descriptionmsg": "wikipoints-description",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"version": "1.1.0",
	"type": "specialpage",
	"license-name": "GPL-3.0-or-later",
	"manifest_version": 2,
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\WikiPoints\\": "includes/"
	},
	"ExtensionMessagesFiles": {
		"WikiPointsAlias": "WikiPoints.i18n.alias.php"
	},
	"HookHandlers": {
		"Main": {
			"class": "MediaWiki\\Extension\\WikiPoints\\Hooks",
			"services": [ "ActorNormalization", "ConnectionProvider" ]
		}
	},
	"Hooks": {
		"BlockIpComplete": "Main",
		"ContributionsToolLinks": "Main",
		"LoadExtensionSchemaUpdates": "MediaWiki\\Extension\\WikiPoints\\Installer::onLoadExtensionSchemaUpdates",
		"PageSaveComplete": "Main",
		"RenameUserComplete": "Main",
		"UnblockUserComplete": "Main"
	},
	"MessagesDirs": {
		"WikiPoints": [
			"i18n"
		]
	},
	"SpecialPages": {
		"WikiPoints": {
			"class": "MediaWiki\\Extension\\WikiPoints\\SpecialWikiPoints",
			"services": [
				"ConnectionProvider",
				"LinkRenderer",
				"SpecialPageFactory",
				"UserFactory",
				"MainWANObjectCache"
			]
		},
		"MostWikiPoints": {
			"class": "MediaWiki\\Extension\\WikiPoints\\SpecialMostWikiPoints",
			"services": [
				"ConnectionProvider",
				"LinkRenderer",
				"SpecialPageFactory",
				"UserFactory",
				"MainWANObjectCache"
			]
		}
	}
}
